{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":dependencyDashboard"
	],
	"packageRules": [
		{
			"matchUpdateTypes": [
				"major",
				"minor",
				"patch",
				"digest",
				"pin",
				"bump"
			],
			"groupName": "all dependencies",
			"groupSlug": "all-deps",
			"schedule": [
				"every weekend"
			]
		}
	],
	"prConcurrentLimit": 1,
	"prHourlyLimit": 0,
	"branchConcurrentLimit": 1,
	"schedule": [
		"every weekend"
	],
	"timezone": "Asia/Tokyo",
	"stabilityDays": 14
}
